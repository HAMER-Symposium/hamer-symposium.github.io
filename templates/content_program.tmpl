      <tr >
        <td  align="center" valign="middle" class="success"><strong><a href="#panel">Session E:<br>Panel Discussion</a></strong><br>Chair: Litsa Kapsalis (MIT)</td>
        <td>4:30 &ndash; 5:30 PM</td>
